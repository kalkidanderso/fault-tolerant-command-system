{
  "name": "skipr-fault-tolerant-system",
  "version": "1.0.0",
  "description": "Fault-tolerant single-agent command execution system",
  "private": true,
  "workspaces": [
    "server",
    "agent"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "dev:server": "npm run dev -w server",
    "dev:agent": "npm run dev -w agent",
    "start:server": "npm run start -w server",
    "start:agent": "npm run start -w agent",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write \"**/*.{ts,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,json,md}\""
  },
  "devDependencies": {
    "@types/node": "^20.10.6",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.1.1",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
